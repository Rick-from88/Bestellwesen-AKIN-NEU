DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bestellwesen
PORT=3000

# TLS für Postgres (Cloud Run → Cloud SQL / verwaltete DB): DB_SSL=true setzen.
# Bei Cloud-SQL-Zertifikatswarnungen: DB_SSL_REJECT_UNAUTHORIZED=false (nur wenn nötig).
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Firebase Admin SDK (für Login/Token-Verifizierung)
# Entweder als JSON String:
# FIREBASE_ADMIN_SDK_JSON='{"type":"service_account",...}'
# oder als Pfad zur serviceAccount.json:
# FIREBASE_ADMIN_SDK_PATH='C:\\pfad\\serviceAccount.json'
FIREBASE_ADMIN_SDK_JSON=
FIREBASE_ADMIN_SDK_PATH=

# Cookie-Name für die Server-Session (Firebase Hosting: nur "__session" wird an Cloud Run durchgereicht)
FB_SESSION_COOKIE=__session

# Admin-Zugriff (z. B. für Nutzerverwaltung). Zusätzlich fest im Code: patrick@akin-pulverbeschichtungen.de
ADMIN_UIDS=
ADMIN_EMAILS=

# FCM Web Push: oeffentlicher VAPID-Schluessel (Firebase Console > Projekteinstellungen > Cloud Messaging > Web-Push-Zertifikate)
FCM_VAPID_PUBLIC_KEY=

# Firebase Hosting-Deploy ohne Browser — eine der beiden Varianten:
#
# A) CI-Token (wenn login:ci funktioniert):
# FIREBASE_TOKEN=...
#
# B) Service-Account-JSON (Google Cloud > IAM > Dienstkonto > Schluessel; Rolle z. B. "Firebase Hosting Admin"):
# GOOGLE_APPLICATION_CREDENTIALS=C:\pfad\hosting-deploy-sa.json
# oder relativer Pfad zum Projektroot, z. B.:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-hosting-ci-sa.json
#
# Dann: npm run deploy:hosting
#
# TLS / Firmenproxy ("unable to verify the first certificate"):
# Besser: Firmen-Root-Zertifikat als .pem und NODE_EXTRA_CA_CERTS=C:\pfad\corp-root.pem
# Notfall (unsicher, nur lokal): BW_TLS_INSECURE_FIREBASE_DEPLOY=1
# BW_TLS_INSECURE_FIREBASE_DEPLOY=
