DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bestellwesen
PORT=3000

# TLS für Postgres (Cloud Run → Cloud SQL / verwaltete DB): DB_SSL=true setzen.
# Bei Cloud-SQL-Zertifikatswarnungen: DB_SSL_REJECT_UNAUTHORIZED=false (nur wenn nötig).
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Firebase Admin SDK (für Login/Token-Verifizierung)
# Entweder als JSON String:
# FIREBASE_ADMIN_SDK_JSON='{"type":"service_account",...}'
# oder als Pfad zur serviceAccount.json:
# FIREBASE_ADMIN_SDK_PATH='C:\\pfad\\serviceAccount.json'
FIREBASE_ADMIN_SDK_JSON=
FIREBASE_ADMIN_SDK_PATH=

# Cookie-Name für die Server-Session (Firebase Hosting: nur "__session" wird an Cloud Run durchgereicht)
FB_SESSION_COOKIE=__session

# Admin-Zugriff (z. B. für Nutzerverwaltung). Zusätzlich fest im Code: patrick@akin-pulverbeschichtungen.de
ADMIN_UIDS=
ADMIN_EMAILS=
